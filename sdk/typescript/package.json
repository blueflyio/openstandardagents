{
  "name": "@ossa/uadp",
  "version": "0.1.0",
  "description": "Universal AI Discovery Protocol (UADP) client and server SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./client": { "import": "./dist/client.js", "types": "./dist/client.d.ts" },
