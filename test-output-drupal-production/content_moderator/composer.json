{
  "name": "drupal/content_moderator",
  "type": "drupal-module",
  "description": "AI-powered content moderation agent for Drupal with ai_agents integration",
  "keywords": [
    "Drupal",
    "OSSA",
    "AI",
    "Agent",
    "ai_agents"
  ],
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1",
    "drupal/core": "^10 || ^11",
    "drupal/ai_agents": "^1.3"
  },
  "require-dev": {
    "drupal/core-dev": "^10 || ^11",
    "phpunit/phpunit": "^9.5"
  },
  "extra": {
    "ossa": {
      "version": "1.0.0",
      "apiVersion": "ossa/v0.4.x",
      "kind": "Agent",
      "integration": "ai_agents_1.3.x"
    },
    "drupal/core": {
      "core-version-requirement": "^10 || ^11"
    }
  }
}