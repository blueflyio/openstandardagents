{
  "acls": [
    {
      "action": "accept",
      "src": ["tag:agent-mesh"],
      "dst": ["*:3005"],
      "comment": "Agent mesh nodes can reach the SOD enforcement endpoint"
    },
    {
      "action": "accept",
      "src": ["tag:nas"],
      "dst": ["*:9090"],
      "comment": "NAS monitoring can reach Prometheus metrics endpoint"
    },
    {
      "action": "accept",
      "src": ["tag:agent-mesh"],
      "dst": ["*:3001"],
      "comment": "Agent mesh nodes can reach the API gateway"
    },
    {
      "action": "accept",
      "src": ["tag:admin"],
      "dst": ["*:*"],
      "comment": "Admin nodes have full access for debugging"
    }
  ],
  "tagOwners": {
    "tag:agent-mesh": ["autogroup:admin"],
    "tag:nas": ["autogroup:admin"],
    "tag:admin": ["autogroup:admin"]
  },
  "ssh": [
    {
      "action": "accept",
      "src": ["tag:admin"],
      "dst": ["tag:agent-mesh"],
      "users": ["autogroup:nonroot"]
    }
  ],
  "tests": [
    {
      "src": "tag:agent-mesh",
      "accept": ["*:3005", "*:3001"],
      "deny": ["*:9090"]
    },
    {
      "src": "tag:nas",
      "accept": ["*:9090"],
      "deny": ["*:3005"]
    }
  ]
}
