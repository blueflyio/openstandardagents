{
  "tunnel": {
    "name": "bluefly-agent-tunnel",
    "credentials-file": "/etc/cloudflared/credentials.json"
  },
  "ingress": [
    {
      "hostname": "mesh.blueflyagents.com",
      "service": "http://localhost:3005",
      "originRequest": {
        "connectTimeout": "30s",
        "noTLSVerify": false
      },
      "access": {
        "required": true,
        "teamName": "bluefly",
        "policies": [
          {
            "name": "SOD Agent Mesh Access",
            "decision": "allow",
            "include": [
              {
                "service_token": {
                  "token_id": "{{MESH_SERVICE_TOKEN_ID}}"
                }
              }
            ],
            "require": [],
            "exclude": []
          }
        ],
        "sessionDuration": "1h"
      }
    },
    {
      "hostname": "api.blueflyagents.com",
      "service": "http://localhost:3001",
      "originRequest": {
        "connectTimeout": "30s",
        "noTLSVerify": false
      },
      "access": {
        "required": true,
        "teamName": "bluefly",
        "policies": [
          {
            "name": "SOD API Access",
            "decision": "allow",
            "include": [
              {
                "service_token": {
                  "token_id": "{{API_SERVICE_TOKEN_ID}}"
                }
              }
            ],
            "require": [],
            "exclude": []
          }
        ],
        "sessionDuration": "1h"
      }
    },
    {
      "service": "http_status:404"
    }
  ]
}
