{
  "name": "@bluefly/duadp-node",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create duadp-store",
    "db:migrate": "wrangler d1 execute duadp-store --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute duadp-store --file=./migrations/0001_init.sql --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
