# Drupal MCP Server Configuration

# Base URL of your Drupal site (required)
DRUPAL_BASE_URL=https://your-drupal-site.com

# Authentication type: oauth2, api-key, or jwt
DRUPAL_AUTH_TYPE=oauth2

# OAuth2 Authentication (requires oauth2 type)
DRUPAL_CLIENT_ID=your-client-id
DRUPAL_CLIENT_SECRET=your-client-secret
# Optional: Use password grant
DRUPAL_USERNAME=your-username
DRUPAL_PASSWORD=your-password

# API Key Authentication (requires api-key type)
DRUPAL_API_KEY=your-api-key

# JWT Authentication (requires jwt type)
DRUPAL_JWT_TOKEN=your-jwt-token
