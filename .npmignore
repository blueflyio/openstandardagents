src/tools/
generate-all-services.ts
pyrightconfig.json
*.mjs
test-*.mjs
demo-*.mjs
export-*.mjs

# Infrastructure and deployment (not part of package)
infrastructure/
deployment/
src/deployment-templates/
hooks/
migrations/
docker-compose.yml
Dockerfile
Dockerfile.*
nginx.conf
devfile.yaml

# Development context files
llms.txt
llms-ctx*.txt
.wiki-config.json
