# OSSA - npm Package Exclusions
# Only include what's needed for the npm package
# This file complements package.json "files" array

# Development directories
.agents-workspace/
.agents/
.cursor/
.claude/
.vscode/
.gitlab/
.github/
.git/
.worktrees/
.husky/
.lefthook/
.kiro/

# Build artifacts (generated during prepublishOnly)
coverage/
*.log
*.tsbuildinfo
junit.xml
*.tgz
test-results/
test-output*/
tmp/
tmp-*/
.mutation/

# Test files
tests/
**/*.test.ts
**/*.spec.ts
playwright.config.ts
jest.config.ts
tsconfig.test.json

# Source files (we ship dist/)
src/
tsconfig.json

# CLI source (legacy - bin/ is the entry point)
cli/

# Development files
.env
.env.*
!.env.example
.DS_Store
*.swp
*.swo
*~

# GitLab CI/CD and build tooling
.gitlab-ci.yml
lefthook.yml
cliff.toml
.releaserc.json
release.config.js
.spectral.yaml
.redocly.yaml
.prettierrc.json
.prettierignore

