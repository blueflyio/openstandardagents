# Duplicate directories
ossa-standard/

# Hooks
hooks/

# Public folder (GitLab Pages only)
public/

# Keep these for npm package (listed in package.json "files"):
# - dist/ (compiled TypeScript code)
# - bin/ (CLI entry point)
# - spec/ (OSSA specification files)
# - schemas/ (JSON schemas)
# - examples/ (reference examples)
# - openapi/ (OpenAPI specifications)
# - README.md
# - LICENSE
# - CHANGELOG.md
# - package.json
