{
  "$id": "https://ossa.dev/schema/components/metadata.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OSSA Metadata Component",
  "description": "Reusable metadata block for OSSA resources",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
      "maxLength": 63,
      "description": "DNS-1123 compliant resource name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$",
      "description": "Semantic version string"
    },
    "description": {
      "type": "string",
      "maxLength": 1024,
      "description": "Human-readable description"
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Key-value labels for categorization"
    },
    "annotations": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Key-value annotations for tooling"
    },
    "uuid": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique identifier for the agent"
    },
    "machine_name": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "System-friendly identifier used by Drupal and other CMS"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "deprecated", "revoked"],
      "description": "Publication lifecycle status of the agent"
    }
  },
  "required": ["name", "version"],
  "additionalProperties": false
}
