{
  "id": "baseline",
  "name": "OSSA Baseline Profile",
  "version": "0.3.0",
  "description": "Minimum required features for OSSA agent conformance",
  "required": {
    "features": ["apiVersion", "kind", "metadata.name", "spec.role", "spec.llm"],
    "weight": 0.6
  },
  "optional": {
    "features": ["spec.tools", "spec.autonomy", "spec.observability"],
    "weight": 0.4
  },
  "constraints": {},
  "scoring": {
    "pass_threshold": 0.6,
    "warn_threshold": 0.8
  }
}
